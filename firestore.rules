rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isReception() { return hasRole('reception'); }
    function isGovernance() { return hasRole('governance'); }
    function isMaintenance() { return hasRole('maintenance'); }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.size() >= 4 &&
             data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 100 &&
             data.role in ['reception', 'governance', 'maintenance'];
    }

    function isValidTicket(data) {
      return data.size() >= 7 &&
             data.roomNumber is string && data.roomNumber.size() > 0 && data.roomNumber.size() <= 10 &&
             data.department in ['governance', 'maintenance'] &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 1000 &&
             data.priority in ['low', 'medium', 'high', 'urgent'] &&
             data.status in ['open', 'in-progress', 'completed', 'cancelled'] &&
             data.openedBy == request.auth.uid &&
             data.createdAt == request.time;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) &&
                       isValidUser(incoming()) &&
                       incoming().role == existing().role; // Immutable role after creation
    }

    match /tickets/{ticketId} {
      allow list: if isSignedIn() && (
        isReception() ||
        (isGovernance() && resource.data.department == 'governance') ||
        (isMaintenance() && resource.data.department == 'maintenance')
      );

      allow get: if isSignedIn();

      allow create: if isReception() && isValidTicket(incoming());

      allow update: if isSignedIn() && (
        // Reception can update anything
        (isReception() && incoming() != null) ||
        // Staff can only update status and assignedTo
        ((isGovernance() || isMaintenance()) &&
         existing().department == getUserData().role &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'assignedTo', 'updatedAt']) &&
         incoming().updatedAt == request.time
        )
      );

      allow delete: if isReception();
    }

    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow write: if isReception();
    }
  }
}
